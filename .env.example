SIST_IONM_APP_NAME=SIST-iONM
SIST_IONM_ENVIRONMENT=development
SIST_IONM_DEBUG=false
SIST_IONM_TIMEZONE=America/Sao_Paulo
SIST_IONM_DATABASE_URL=postgresql+psycopg://sist_ionm:local_change_me@db:5432/sist_ionm
SIST_IONM_SESSION_SECRET=replace_with_at_least_32_random_characters
SIST_IONM_SMTP_ENCRYPTION_KEY=replace_with_a_valid_fernet_key
SIST_IONM_STORAGE_ROOT=storage
SIST_IONM_LEGACY_SQLITE_PATH=data/overpriceon_web.db
POSTGRES_DB=sist_ionm
POSTGRES_USER=sist_ionm
POSTGRES_PASSWORD=local_change_me

# WhatsApp Business Cloud API / Meta
WHATSAPP_ENABLED=false
WHATSAPP_SECRET_KEY=replace_with_at_least_32_random_characters_outside_the_database
WHATSAPP_API_VERSION=v23.0
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WABA_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_PATH=/integrations/whatsapp/webhook
